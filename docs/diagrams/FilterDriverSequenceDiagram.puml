@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":FilterCommandParser" as FilterCommandParser LOGIC_COLOR
participant "d:DriverAssignedToPersonPredicate" as DriverAssignedToPersonPredicate LOGIC_COLOR
participant "f:FilterCommand" as FilterCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
participant "p:Person" as Person MODEL_COLOR
participant "dr:Driver" as Driver MODEL_COLOR
end box

[-> LogicManager : execute("filter d/Alex d/Jordan")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("filter d/Alex d/Jordan")
activate AddressBookParser

create FilterCommandParser
AddressBookParser -> FilterCommandParser
activate FilterCommandParser

FilterCommandParser --> AddressBookParser
deactivate FilterCommandParser

AddressBookParser -> FilterCommandParser : parse("d/Alex d/Jordan")
activate FilterCommandParser

create DriverAssignedToPersonPredicate
FilterCommandParser -> DriverAssignedToPersonPredicate
activate DriverAssignedToPersonPredicate

DriverAssignedToPersonPredicate --> FilterCommandParser
deactivate DriverAssignedToPersonPredicate

create FilterCommand
FilterCommandParser -> FilterCommand
activate FilterCommand

FilterCommand --> FilterCommandParser
deactivate FilterCommand

FilterCommandParser --> AddressBookParser : f
deactivate FilterCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
FilterCommandParser -[hidden]-> AddressBookParser
destroy FilterCommandParser

AddressBookParser --> LogicManager : f
deactivate AddressBookParser

LogicManager -> FilterCommand : execute(m)
activate FilterCommand

FilterCommand -> Model : updateFilteredPersonList(d)
activate Model

loop for each person in the list
    Model -> DriverAssignedToPersonPredicate : test(p)
    activate DriverAssignedToPersonPredicate

    alt person has an assigned driver
        DriverAssignedToPersonPredicate -> Person : getAssignedDriver()
        activate Person

        Person -> Driver : new Driver(name, phone)
        activate Driver

        Driver --> Person : dr
        deactivate Driver

        Person --> DriverAssignedToPersonPredicate : dr
        deactivate Person

        DriverAssignedToPersonPredicate -> Driver : getName()
        activate Driver

        Driver --> DriverAssignedToPersonPredicate : name
        deactivate Driver
    else person has no assigned driver
        DriverAssignedToPersonPredicate -> Person : getAssignedDriver()
        activate Person

        Person --> DriverAssignedToPersonPredicate : DriverNotFoundException
        deactivate Person
    end

    DriverAssignedToPersonPredicate --> Model : matches / false
    deactivate DriverAssignedToPersonPredicate
end

Model --> FilterCommand
deactivate Model

create CommandResult
FilterCommand -> CommandResult
activate CommandResult

CommandResult --> FilterCommand
deactivate CommandResult

FilterCommand --> LogicManager : r
deactivate FilterCommand

[<--LogicManager
deactivate LogicManager
@enduml
